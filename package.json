{
  "name": "claude-code-discord-bridge",
  "version": "0.1.0",
  "description": "Control Claude Code from your phone via Discord",
  "license": "Apache-2.0",
  "type": "module",
  "keywords": ["claude", "claude-code", "discord", "mcp", "plugin", "bridge", "mobile", "remote"],
  "repository": {
    "type": "git",
    "url": "https://github.com/chrismdemian/claude-code-discord-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/chrismdemian/claude-code-discord-bridge/issues"
  },
  "homepage": "https://github.com/chrismdemian/claude-code-discord-bridge",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "start": "bun server.ts",
    "bridge": "bun run bridge/index.ts",
    "dev": "bun --watch bridge/index.ts",
    "build": "bun build bridge/index.ts --outdir dist --target bun",
    "server": "bun run server.ts",
    "check": "tsc --noEmit",
    "setup": "bun run bridge/setup.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "discord.js": "^14.16.0",
    "chokidar": "^4.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
